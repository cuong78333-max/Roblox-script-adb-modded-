-- ============================================================================
-- MAIN KILL AURA LOOP (Integrated Aimbot + Skill Combo)
-- ============================================================================

local comboRoundRobinCounter = 0
local comboOrderList = {"Combo1", "Combo2", "Combo3", "Combo4", "Combo5"}

task.spawn(function()
    while true do
        task.wait(0.05)  -- 50ms loop for responsive skill execution
        
        if _G.KillAura then
            pcall(function()
                local character = LocalPlayer.Character
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                if not rootPart then return end
                
                local targets = {}
                for _, npc in pairs(workspace:GetChildren()) do
                    if npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc:FindFirstChild("HumanoidRootPart") then
                        if not Players:GetPlayerFromCharacter(npc) and npc.Name ~= LocalPlayer.Name then
                            local humanoid = npc:FindFirstChild("Humanoid")
                            if humanoid and humanoid.Health > 0 then
                                if _G.SelectedBoss == "All Bosses" or _G.SelectedBoss == npc.Name then
                                    table.insert(targets, npc)
                                end
                            end
                        end
                    end
                end
                
                if #targets == 0 then return end
                
                -- Select nearest target
                table.sort(targets, function(a, b)
                    local distA = (rootPart.Position - a.HumanoidRootPart.Position).Magnitude
                    local distB = (rootPart.Position - b.HumanoidRootPart.Position).Magnitude
                    return distA < distB
                end)
                
                local target = targets[1]
                if not target then return end
                
                -- Teleport behind target (backstab)
                TeleportToBossBack(target)
                task.wait(0.03)
                
                -- === SKILL COMBO EXECUTION ===
                -- Execute combos in round-robin fashion
                comboRoundRobinCounter = comboRoundRobinCounter + 1
                if comboRoundRobinCounter > #comboOrderList then
                    comboRoundRobinCounter = 1
                end
                
                local currentComboName = comboOrderList[comboRoundRobinCounter]
                local comboExecuted = ExecuteCombo(currentComboName)
                
                -- If no combo executed, fallback to individual skills
                if not comboExecuted then
                    local keyOrder = {"E", "R", "T", "Y", "F", "Z", "X", "C", "V", "B", "J"}
                    for _, key in ipairs(keyOrder) do
                        if _G.ActiveSkills[key] then
                            pcall(function()
                                VirtualInputManager:SendKeyEvent(true, KeyMapping[key], false, game)
                                task.wait(0.04)
                                VirtualInputManager:SendKeyEvent(false, KeyMapping[key], false, game)
                            end)
                            task.wait(0.06)
                        end
                    end
                end
                
                -- Additional damage after skills
                task.wait(0.02)
                DamageEvent:FireServer(target.Humanoid, target.HumanoidRootPart.CFrame, 80, 0, Vector3.new(0,0,0), "Normal", 0)
            end)
        end
    end
end)

