]]

local function ScanWorkspace()
    local bosses = {}
    local names = {}
    
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj:IsA("Model") and obj.Name ~= LocalPlayer.Name and IsBoss(obj) and IsAlive(obj) then
            local alreadyAdded = false
            for _, boss in ipairs(bosses) do
                if boss == obj then
                    alreadyAdded = true
                    break
                end
            end
            if not alreadyAdded then
                table.insert(bosses, obj)
                local display = obj.Name or "Unknown"
                local hum = GetHumanoid(obj)
                if hum and hum.Health then
                    display = display .. " [" .. math.floor(hum.Health) .. "HP]"
                end
                table.insert(names, display)
            end
        end
    end
    
    return bosses, names
end

