    local Box = Instance.new("TextBox")
    Box.Size, Box.Position, Box.BackgroundColor3 = UDim2.new(0, 80, 1, 0), UDim2.new(0, 130, 0, 0), Color3.fromRGB(15, 15, 15)
    Box.Text, Box.TextColor3, Box.Font, Box.TextSize, Box.Parent = tostring(defaultValue), Color3.fromRGB(255, 255, 255), Enum.Font.SourceSansBold, 12, Row
    Instance.new("UICorner", Box).CornerRadius = UDim.new(0, 4)
    Box.FocusLost:Connect(function()
        local val = tonumber(Box.Text)
        if val and val >= 0 then updateCallback(val) else Box.Text = tostring(defaultValue) end
    end)
end

