local function UseItem(itemName)
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    if not bp or not char then return false end
    local item = bp:FindFirstChild(itemName)
    if not item and char:FindFirstChild(itemName) then item = char[itemName] end
    if item then
        item.Parent = char
        task.wait(0.2)
        item:Activate()
        task.wait(0.4)
        return true
    end
    return false
end

local function BypassYesButton()
    pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            for _, gui in pairs(pGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled then
                    for _, btn in pairs(gui:GetDescendants()) do
                        if btn:IsA("TextButton") and (string.upper(btn.Text) == "YES" or btn.Name == "Yes" or btn.Name == "YES") and btn.Visible then
                            local ap = btn.AbsolutePosition
                            local as = btn.AbsoluteSize
                            if ap and as then
                                VirtualInputManager:SendMouseButtonEvent(ap.X + (as.X/2), ap.Y + (as.Y/2) + 36, 0, true, game, 0)
                                task.wait(0.05)
                                VirtualInputManager:SendMouseButtonEvent(ap.X + (as.X/2), ap.Y + (as.Y/2) + 36, 0, false, game, 0)
                                return true
                            end
                        end
                    end
                end
            end
        end
    end)
    return false
end

