--[[
    ============================================================
    ABD OPTIMIZED SCRIPT - PART 11/21
    AUTO SUMMON STAND
    ============================================================
]]

local function AutoSummonStand()
    if not Settings.AutoSummonEnabled then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local hum = GetHumanoid(char)
    if not hum then return end
    
    if hum.Health and hum.Health <= 0 then
        State.IsDead = true
        return
    end
    
    if State.IsDead or not State.HasStand then
        if State.IsDead then
            State.IsDead = false
            task.wait(1.5)
        end
        
        local now = tick()
        if now >= State.Timers["Q"] then
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, "Q", false, nil)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, "Q", false, nil)
            end)
            State.Timers["Q"] = now + Settings.SkillCooldowns["Q"]
            State.StatusText = "Summoning Stand..."
            
            task.wait(0.5)
            ScanForStand()
        end
    end
end

