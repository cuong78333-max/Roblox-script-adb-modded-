local function RefreshDropdown()
    if not MainFrame.Visible then return end
    for _, child in pairs(ScrollingFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    local AllBtn = Instance.new("TextButton")
    AllBtn.Size, AllBtn.Font, AllBtn.TextSize = UDim2.new(1, -6, 0, 30), Enum.Font.SourceSansBold, 12
    AllBtn.BackgroundColor3 = (_G.SelectedBoss == "All Bosses") and Color3.fromRGB(60, 60, 60) or Color3.fromRGB(25, 25, 25)
    AllBtn.Text, AllBtn.TextColor3, AllBtn.Parent = "⭐ ALL BOSSES", Color3.fromRGB(255, 255, 255), ScrollingFrame
    Instance.new("UICorner", AllBtn).CornerRadius = UDim.new(0, 4)
    AllBtn.MouseButton1Click:Connect(function() _G.SelectedBoss = "All Bosses" SelectTitle.Text = "MỤC TIÊU: All Bosses" RefreshDropdown() end)
    local count = 1
    for _, npc in pairs(workspace:GetChildren()) do
        if npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc:FindFirstChild("HumanoidRootPart") then
            if not Players:GetPlayerFromCharacter(npc) and npc.Name ~= LocalPlayer.Name and npc.Humanoid.Health > 0 then
                count = count + 1
                local BossBtn = Instance.new("TextButton")
                BossBtn.Size, BossBtn.Font, BossBtn.TextSize = UDim2.new(1, -6, 0, 30), Enum.Font.SourceSans, 12
                BossBtn.BackgroundColor3 = (_G.SelectedBoss == npc.Name) and Color3.fromRGB(255, 140, 0) or Color3.fromRGB(25, 25, 25)
                BossBtn.Text, BossBtn.TextColor3, BossBtn.Parent = npc.Name .. " [" .. math.floor(npc.Humanoid.Health) .. "]", Color3.fromRGB(220, 220, 220), ScrollingFrame
                Instance.new("UICorner", BossBtn).CornerRadius = UDim.new(0, 4)
                BossBtn.MouseButton1Click:Connect(function() _G.SelectedBoss = npc.Name SelectTitle.Text = "MỤC TIÊU: " .. npc.Name RefreshDropdown() end)
            end
        end
    end
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, count * 34)
end
