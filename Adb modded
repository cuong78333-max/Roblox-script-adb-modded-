-- ============================================================
-- PART 11: INITIALIZATION
-- ============================================================

local function Initialize()
    -- Wait for character
    for i = 1, 10 do
        if LocalPlayer and LocalPlayer.Character and 
           LocalPlayer.Character:FindFirstChild("Humanoid") then
            break
        end
        task.wait(0.5)
    end
    
    -- Create UI with retry
    local success = false
    for attempt = 1, 3 do
        success, err = pcall(CreateUI)
        if success then
            print("[ABD] UI Loaded on attempt " .. attempt)
            break
        else
            warn("[ABD] Attempt " .. attempt .. " failed: " .. tostring(err))
            task.wait(1)
        end
    end
    
    if not success then
        warn("[ABD] All UI attempts failed. Please re-execute.")
    end
    
    print("[ABD] ===== SCRIPT LOADED SUCCESSFULLY =====")
    print("[ABD] Game ID: " .. game.PlaceId)
    print("[ABD] Press START to begin")
end

