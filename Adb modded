--[[
    ============================================================
    ABD OPTIMIZED SCRIPT - PART 9/21
    AUTO SUMMON STAND - FIXED
    ============================================================
]]

local function AutoSummonStand()
    if not Settings.AutoSummonEnabled then return end
    
    local char = LocalPlayer.Character
    if not char then 
        WaitForCharacter()
        return 
    end
    
    local hum = GetHumanoid(char)
    if not hum then return end
    
    -- Check if dead
    if hum.Health and hum.Health <= 0 then
        State.IsDead = true
        return
    end
    
    -- Scan for stand
    ScanForStand()
    
    -- Check if need to summon
    local needSummon = false
    
    -- If dead and respawned
    if State.IsDead then
        State.IsDead = false
        needSummon = true
        task.wait(0.5)
    end
    
    -- If no stand detected
    if not State.HasStand then
        needSummon = true
    end
    
    -- Check if stand is in backpack but not summoned
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, child in ipairs(backpack:GetChildren()) do
            local name = child.Name:lower()
            if name:find("stand") or name:find("ability") or name:find("power") then
                needSummon = true
                break
            end
        end
    end
    
    -- Perform summon
    if needSummon then
        local now = tick()
        if now - State.LastSummonTime >= Settings.SkillCooldowns["Q"] then
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, "Q", false, nil)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, "Q", false, nil)
            end)
            State.LastSummonTime = now
            State.StatusText = "Summoning Stand..."
            State.Timers["Q"] = now + Settings.SkillCooldowns["Q"]
            
            -- Wait and check again
            task.wait(0.8)
            ScanForStand()
            
            if State.HasStand then
                State.StatusText = "Stand summoned: " .. State.StandName
            else
                State.StatusText = "Stand summon failed, retrying..."
            end
        end
    end
end

