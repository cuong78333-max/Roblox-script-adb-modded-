--[[
    ============================================================
    ABD OPTIMIZED SCRIPT - PART 8/21
    STAND DETECTION - IMPROVED
    ============================================================
]]

local function ScanForStand()
    local char = LocalPlayer.Character
    if not char then 
        State.HasStand = false
        State.StandName = "None"
        return false
    end
    
    local standFound = false
    local standName = "None"
    local standData = {}
    
    -- Check character's children thoroughly
    for _, child in ipairs(char:GetChildren()) do
        local name = child.Name or ""
        local lower = name:lower()
        
        -- Check for stand indicators in names
        if lower:find("stand") or lower:find("ability") or lower:find("power") or
           lower:find("summon") or lower:find("spirit") or lower:find("ghost") or
           lower:find("requiem") or lower:find("over heaven") or lower:find("act") then
            standFound = true
            standName = child.Name
            table.insert(standData, child)
        end
        
        -- Check for stand model
        if child:IsA("Model") then
            for _, sub in ipairs(child:GetChildren()) do
                if sub:IsA("BasePart") then
                    local subName = sub.Name:lower()
                    if subName:find("stand") or subName:find("body") or 
                       subName:find("arm") or subName:find("leg") or subName:find("head") then
                        standFound = true
                        if standName == "None" then
                            standName = child.Name
                        end
                        table.insert(standData, child)
                        break
                    end
                end
            end
        end
        
        -- Check for Humanoid with special name
        if child:IsA("Humanoid") and lower:find("stand") then
            standFound = true
            standName = child.Name
            table.insert(standData, child)
        end
    end
    
    -- Check workspace for stand nearby
    if not standFound then
        local charRoot = GetRoot(char)
        if charRoot then
            for _, obj in ipairs(Workspace:GetChildren()) do
                if obj:IsA("Model") and obj ~= char then
                    local objName = obj.Name:lower()
                    if objName:find("stand") or objName:find("ability") or objName:find("spirit") or
                       objName:find("requiem") or objName:find("heaven") then
                        local objRoot = GetRoot(obj)
                        if objRoot then
                            local dist = (charRoot.Position - objRoot.Position).Magnitude
                            if dist < 25 then
                                standFound = true
                                standName = obj.Name
                                table.insert(standData, obj)
                                break
                            end
                        end
                    end
                end
            end
        end
    end
    
    -- If still not found, check for Tool in backpack
    if not standFound then
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, child in ipairs(backpack:GetChildren()) do
                local name = child.Name:lower()
                if name:find("stand") or name:find("ability") or name:find("power") then
                    standFound = true
                    standName = child.Name
                    table.insert(standData, child)
                    break
                end
            end
        end
    end
    
    State.HasStand = standFound
    State.StandName = standFound and standName or "None"
    State.StandData = standData
    
    return standFound, standName, standData
end

