--[[
    ============================================================
    ABD OPTIMIZED SCRIPT - PART 14/21
    KILL AURA & FACE TARGET
    ============================================================
]]

local function DoKillAura()
    local target = State.Target
    if not target or not target.Parent then
        target = GetBossByIndex(State.SelectedIndex) or GetClosestBoss()
        State.Target = target
    end
    
    if not target then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local root = GetRoot(char)
    local targetRoot = GetRoot(target)
    
    if not root or not targetRoot then return end
    
    local dist = (root.Position - targetRoot.Position).Magnitude
    
    if State.Teleport or dist > Settings.AuraRadius then
        TeleportBehind(target)
    end
    
    if dist > Settings.AuraRadius then
        return
    end
    
    ExecuteRotation()
end

local function FaceTarget(Target)
    if not Target then return end
    
    local char = LocalPlayer.Character
    if not char then return end
    
    local root = GetRoot(char)
    local targetRoot = GetRoot(Target)
    
    if not root or not targetRoot then return end
    
    pcall(function()
        local look = CFrame.new(root.Position, targetRoot.Position)
        root.CFrame = CFrame.new(root.Position, look.LookVector + root.Position)
    end)
end

print("[ABD] Part 14/21 - Kill Aura & Face Target Loaded")
--[[
    ============================================================
    ABD OPTIMIZED SCRIPT - PART 15/21
    MAIN LOOP
    ============================================================
]]

local function MainLoop()
    if not State.Enabled then return end
    
    AutoSummonStand()
    
    if tick() % Settings.ScanInterval < 0.05 then
        ScanAllBosses()
    end
    
    if tick() % Settings.StandScanInterval < 0.05 then
        ScanForStand()
    end
    
    if State.SelectedIndex > 0 and State.SelectedIndex <= #State.Bosses then
        local selected = GetBossByIndex(State.SelectedIndex)
        if selected and selected.Parent and IsAlive(selected) then
            State.Target = selected
        else
            State.Target = GetClosestBoss()
        end
    else
        State.Target = GetClosestBoss()
    end
    
    if State.Target then
        FaceTarget(State.Target)
        
        if State.Aura then
            DoKillAura()
        end
        
        if State.Teleport then
            local char = LocalPlayer.Character
            if char then
                local root = GetRoot(char)
                local targetRoot = GetRoot(State.Target)
                if root and targetRoot then
                    local dist = (root.Position - targetRoot.Position).Magnitude
                    if dist > 10 then
                        TeleportBehind(State.Target)
                    end
                end
            end
        end
    end
    
    local targetName = State.Target and State.Target.Name or "None"
    if #targetName > 12 then targetName = string.sub(targetName, 1, 10) .. ".." end
    local nextSkill = RotationSkills[State.RotationIndex] or "-"
    State.StatusText = string.format("Stand: %s | Target: %s | Next: %s", 
        State.StandName, targetName, nextSkill)
end

