function UI:CreateComplete()
    local screen, frame = self:Create()
    
    -- Floating button
    floatButton = CreateFloatingButton(screen)
    
    -- Top section
    local toggle, stand = CreateTopSection(frame)
    toggleButton = toggle
    standLabel = stand
    
    -- Boss list
    local container, lframe, count = CreateBossList(frame)
    listContainer = container
    listFrame = lframe
    countLabel = count
    
    -- Skill grid
    local btns = CreateSkillGrid(frame)
    
    -- Delay settings
    local rokaSlider, arrowSlider, sumSlider, autoRoka, autoArrow = CreateDelaySettings(frame)
    
    -- Controls
    local tp, aura, scan, summonBtn, rokaBtn, arrowBtn, status = CreateControls(frame)
    statusLabel = status
    
    -- Floating button toggle
    floatButton.MouseButton1Click:Connect(function()
        frame.Visible = not frame.Visible
        State.MenuVisible = frame.Visible
        floatButton.BackgroundColor3 = frame.Visible and 
            Color3.fromRGB(30, 30, 60) or Color3.fromRGB(60, 30, 30)
    end)
    
    -- Main toggle
    toggle.MouseButton1Click:Connect(function()
        State.Enabled = not State.Enabled
        toggle.Text = State.Enabled and "⏹ STOP" or "▶ START"
        toggle.BackgroundColor3 = State.Enabled and 
            Color3.fromRGB(200, 40, 40) or Color3.fromRGB(30, 130, 30)
        
        if State.Enabled then
            State.RotationIndex = 1
            ScanAllBosses()
            ScanForStand()
            UpdateBossList()
            UpdateStandDisplay()
            State.Target = GetBossByIndex(State.SelectedIndex) or GetClosestBoss()
            
            task.wait(0.3)
            AutoSummonStand()
            
            if State.LoopConnection then
                State.LoopConnection:Disconnect()
            end
            if State.StandLoopConnection then
                State.StandLoopConnection:Disconnect()
            end
            if State.AutoLoopConnection then
                State.AutoLoopConnection:Disconnect()
            end
            
            State.LoopConnection = RunService.Heartbeat:Connect(function()
                if not State.Enabled then return end
                pcall(MainLoop)
                pcall(UpdateStatus)
                
                if tick() % Settings.ScanInterval < 0.05 then
                    pcall(UpdateBossList)
                    pcall(UpdateStandDisplay)
                end
            end)
            
            State.StandLoopConnection = RunService.Heartbeat:Connect(function()
                if not State.Enabled then return end
                if tick() % Settings.StandScanInterval < 0.05 then
                    pcall(ScanForStand)
                    pcall(UpdateStandDisplay)
                end
            end)
        else
            if State.LoopConnection then
                State.LoopConnection:Disconnect()
                State.LoopConnection = nil
            end
            if State.StandLoopConnection then
                State.StandLoopConnection:Disconnect()
                State.StandLoopConnection = nil
            end
            if State.AutoLoopConnection then
                State.AutoLoopConnection:Disconnect()
                State.AutoLoopConnection = nil
            end
            State.StatusText = "Stopped"
            UpdateStatus()
        end
    end)
    
    -- Initial scan
    WaitForCharacter()
    ScanAllBosses()
    ScanForStand()
    UpdateBossList()
    UpdateStandDisplay()
    UpdateStatus()
    
    print("[ABD] Complete UI Created Successfully!")
    return screen
end

