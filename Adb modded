-- Update Functions
local function UpdateBossList()
    if not listContainer then return end
    
    for _, child in ipairs(listContainer:GetChildren()) do
        child:Destroy()
    end
    
    local total = #State.Bosses
    if countLabel then
        countLabel.Text = "Total: " .. total
    end
    
    local yOffset = 0
    local btnHeight = 26
    
    if total == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, btnHeight)
        empty.Position = UDim2.new(0, 0, 0, yOffset)
        empty.BackgroundTransparency = 1
        empty.Text = "No bosses found"
        empty.TextColor3 = Color3.fromRGB(150, 150, 180)
        empty.Font = Enum.Font.Gotham
        empty.TextSize = 11
        empty.Parent = listContainer
        yOffset = yOffset + btnHeight
    else
        for i, name in ipairs(State.BossNames) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, -4, 0, btnHeight)
            btn.Position = UDim2.new(0, 2, 0, yOffset)
            btn.BackgroundColor3 = (i == State.SelectedIndex) and 
                Color3.fromRGB(60, 40, 120) or Color3.fromRGB(30, 30, 50)
            btn.Text = name
            btn.TextColor3 = (i == State.SelectedIndex) and 
                Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 10
            btn.TextXAlignment = Enum.TextXAlignment.Left
            btn.Parent = listContainer
            
            local bcorner2 = Instance.new("UICorner")
            bcorner2.CornerRadius = UDim.new(0, 3)
            bcorner2.Parent = btn
            
            btn.MouseButton1Click:Connect(function()
                State.SelectedIndex = i
                State.Target = GetBossByIndex(i)
                UpdateBossList()
            end)
            
            yOffset = yOffset + btnHeight + 2
        end
    end
    
    listContainer.Size = UDim2.new(1, 0, 0, yOffset)
    if listFrame then
        listFrame.CanvasSize = UDim2.new(0, 0, 0, yOffset)
    end
end

local function UpdateStandDisplay()
    if not standLabel then return end
    standLabel.Text = "🔄 Stand: " .. State.StandName
    if State.HasStand then
        standLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        standLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

local function UpdateStatus()
    if not statusLabel then return end
    statusLabel.Text = State.StatusText
end

-- Complete UI Creation
function UI:CreateComplete()
    local screen, frame = self:Create()
    
    -- Create all sections
    local toggle, stand, menuToggle = CreateTopSection(frame)
    toggleButton = toggle
    standLabel = stand
    
    local container, lframe, count = CreateBossList(frame)
    listContainer = container
    listFrame = lframe
    countLabel = count
    
    local btns = CreateSkillGrid(frame)
    local tp, aura, scan, status, close = CreateControls(frame)
    statusLabel = status
    
    -- Menu Toggle Function
    menuToggle.MouseButton1Click:Connect(function()
        State.MenuVisible = not State.MenuVisible
        frame.Visible = State.MenuVisible
        menuToggle.Text = State.MenuVisible and "Hide" or "Show"
        menuToggle.BackgroundColor3 = State.MenuVisible and 
            Color3.fromRGB(40, 40, 70) or Color3.fromRGB(70, 40, 40)
    end)
    
    -- Main Toggle
    toggle.MouseButton1Click:Connect(function()
        State.Enabled = not State.Enabled
        toggle.Text = State.Enabled and "⏹ STOP" or "▶ START"
        toggle.BackgroundColor3 = State.Enabled and 
            Color3.fromRGB(200, 40, 40) or Color3.fromRGB(30, 130, 30)
        
        if State.Enabled then
            State.RotationIndex = 1
            ScanAllBosses()
            ScanForStand()
            UpdateBossList()
            UpdateStandDisplay()
            State.Target = GetBossByIndex(State.SelectedIndex) or GetClosestBoss()
            
            task.wait(0.3)
            AutoSummonStand()
            
            if State.LoopConnection then
                State.LoopConnection:Disconnect()
            end
            if State.StandLoopConnection then
                State.StandLoopConnection:Disconnect()
            end
            
            State.LoopConnection = RunService.Heartbeat:Connect(function()
                if not State.Enabled then return end
                pcall(MainLoop)
                pcall(UpdateStatus)
                
                if tick() % Settings.ScanInterval < 0.05 then
                    pcall(UpdateBossList)
                    pcall(UpdateStandDisplay)
                end
            end)
            
            State.StandLoopConnection = RunService.Heartbeat:Connect(function()
                if not State.Enabled then return end
                if tick() % Settings.StandScanInterval < 0.05 then
                    pcall(ScanForStand)
                    pcall(UpdateStandDisplay)
                end
            end)
        else
            if State.LoopConnection then
                State.LoopConnection:Disconnect()
                State.LoopConnection = nil
            end
            if State.StandLoopConnection then
                State.StandLoopConnection:Disconnect()
                State.StandLoopConnection = nil
            end
            State.StatusText = "Stopped"
            UpdateStatus()
        end
    end)
    
    -- Initial scan
    ScanAllBosses()
    ScanForStand()
    UpdateBossList()
    UpdateStandDisplay()
    UpdateStatus()
    
    print("[ABD] Complete UI Created Successfully!")
    return screen
end

-- Initialize
local function Initialize()
    for i = 1, 10 do
        if LocalPlayer and LocalPlayer.Character and 
           LocalPlayer.Character:FindFirstChild("Humanoid") then
            break
        end
        task.wait(0.5)
    end
    
    local success = false
    for attempt = 1, 3 do
        success, err = pcall(UI.CreateComplete, UI)
        if success then
            print("[ABD] UI Loaded on attempt " .. attempt)
            break
        else
            warn("[ABD] Attempt " .. attempt .. " failed: " .. tostring(err))
            task.wait(1)
        end
    end
    
    if not success then
        warn("[ABD] All UI attempts failed.")
    end
    
    print("[ABD] ===== SCRIPT LOADED SUCCESSFULLY =====")
    print("[ABD] Game ID: " .. game.PlaceId)
    print("[ABD] Features: Auto-scan, Boss List, Stand Detection, Skill Rotation")
    print("[ABD] Press START to begin | Hide/Show menu with Hide button")
end

