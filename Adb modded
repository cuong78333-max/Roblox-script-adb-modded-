}

local CurrentRound = 1

task.spawn(function()
    while true do task.wait(0.2)
        if _G.KillAura then
            pcall(function()
                local character = LocalPlayer.Character
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                if not rootPart then return end
                for _, npc in pairs(workspace:GetChildren()) do
                    if not _G.KillAura then break end
                    if npc:IsA("Model") and npc:FindFirstChild("Humanoid") and npc:FindFirstChild("HumanoidRootPart") and not Players:GetPlayerFromCharacter(npc) and npc.Name ~= LocalPlayer.Name and npc.Humanoid.Health > 0 then
                        if _G.SelectedBoss == "All Bosses" or _G.SelectedBoss == npc.Name then
                            rootPart.CFrame = npc.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3.5)
                            DamageEvent:FireServer(npc.Humanoid, npc.HumanoidRootPart.CFrame, 150, 0, Vector3.new(0,0,0), "Normal", 0)
                            task.wait(0.05)
                            local Round = SkillRounds[CurrentRound]

                            for _, key in ipairs(Round) do
                                if not _G.KillAura then break end
                                if _G.ActiveSkills[key] then
                                    pcall(function()
                                        VirtualInputManager:SendKeyEvent(true, KeyMapping[key], false, game)
                                        task.wait(0.10)
                                        VirtualInputManager:SendKeyEvent(false, KeyMapping[key], false, game)
                                    end)
                                    task.wait(0.15)
                                end
                            end

                            CurrentRound = CurrentRound + 1
                            if CurrentRound > #SkillRounds then
                                CurrentRound = 1
                            end
                        end
                    end
                end
            end)
        end
    end
end)

