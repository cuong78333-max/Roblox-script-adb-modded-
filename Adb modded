local function UseItem(itemName)
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    if not bp or not char then return false end
    local item = bp:FindFirstChild(itemName)
    if not item and char:FindFirstChild(itemName) then item = char[itemName] end
    if item then
        item.Parent = char
        task.wait(0.2)
        item:Activate()
        task.wait(0.4)
        return true
    end
    return false
end

local function BypassYesButton()
    pcall(function()
        local pGui = LocalPlayer:FindFirstChild("PlayerGui")
        if pGui then
            for _, gui in pairs(pGui:GetChildren()) do
                if gui:IsA("ScreenGui") and gui.Enabled then
                    for _, btn in pairs(gui:GetDescendants()) do
                        if btn:IsA("TextButton") and (string.upper(btn.Text) == "YES" or btn.Name == "Yes" or btn.Name == "YES") and btn.Visible then
                            local ap = btn.AbsolutePosition
                            local as = btn.AbsoluteSize
                            if ap and as then
                                VirtualInputManager:SendMouseButtonEvent(ap.X + (as.X/2), ap.Y + (as.Y/2) + 36, 0, true, game, 0)
                                task.wait(0.05)
                                VirtualInputManager:SendMouseButtonEvent(ap.X + (as.X/2), ap.Y + (as.Y/2) + 36, 0, false, game, 0)
                                return true
                            end
                        end
                    end
                end
            end
        end
    end)
    return false
end

-- ============================================================================
-- SKILL EXECUTION FUNCTIONS
-- ============================================================================

local function ExecuteCombo(comboName)
    local combo = _G.SkillCombos[comboName]
    if not combo or not combo.Enabled then return false end
    
    local executed = false
    for _, key in ipairs(combo.Keys) do
        if _G.ActiveSkills[key] then
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, KeyMapping[key], false, game)
                task.wait(0.03)
                VirtualInputManager:SendKeyEvent(false, KeyMapping[key], false, game)
            end)
            executed = true
            task.wait(combo.Delay)
        end
    end
    return executed
end

local function ExecuteAllActiveSkills()
    local keyOrder = {"E", "R", "T", "Y", "F", "Z", "X", "C", "V", "B", "J"}
    for _, key in ipairs(keyOrder) do
        if _G.ActiveSkills[key] then
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, KeyMapping[key], false, game)
                task.wait(0.05)
                VirtualInputManager:SendKeyEvent(false, KeyMapping[key], false, game)
            end)
            task.wait(0.1)
        end
    end
end

local function ExecuteComboRoundRobin()
    local comboOrder = {"Combo1", "Combo2", "Combo3", "Combo4", "Combo5"}
    for _, comboName in ipairs(comboOrder) do
        if _G.SkillCombos[comboName] and _G.SkillCombos[comboName].Enabled then
            ExecuteCombo(comboName)
            task.wait(0.05)
        end
    end
end

-- ============================================================================
-- AIMBOT + TELEPORT BACKSTAB FUNCTION (Enhanced)
-- ============================================================================

local function TeleportToBossBack(npc)
    if not npc or not npc:IsA("Model") then return false end
    local hrp = npc:FindFirstChild("HumanoidRootPart")
    local humanoid = npc:FindFirstChild("Humanoid")
    if not hrp or not humanoid or humanoid.Health <= 0 then return false end
    
    local char = LocalPlayer.Character
    if not char then return false end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    -- Calculate backstab position (behind NPC)
    local lookVector = hrp.CFrame.LookVector
    local backPosition = hrp.Position - (lookVector * 3.5)
    -- Slight offset to avoid clipping
    backPosition = backPosition + Vector3.new(0, 0.5, 0)
    -- Teleport player behind boss
    rootPart.CFrame = CFrame.new(backPosition, hrp.Position)
    task.wait(0.02)
    
    -- Fire damage event for backstab bonus
