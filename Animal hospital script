						Position = UDim2New(
							StartPosition.X.Scale,
							StartPosition.X.Offset + DragDelta.X,
							StartPosition.Y.Scale,
							StartPosition.Y.Offset + DragDelta.Y
						)
					}, true)
				end
			end)
			return Dragging
		end
